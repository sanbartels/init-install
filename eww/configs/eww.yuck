;; Floating horizontal system widget for Hyprland

(defpoll sys_time :interval "10s" "~/.config/eww/scripts/system-widget-info time")
(defpoll sys_cpu  :interval "2s"  "~/.config/eww/scripts/system-widget-info cpu")
(defpoll sys_ram  :interval "2s"  "~/.config/eww/scripts/system-widget-info ram")
(defpoll sys_disk :interval "30s" "~/.config/eww/scripts/system-widget-info disk")
(defpoll sys_net  :interval "2s"  "~/.config/eww/scripts/system-widget-info net")

(defpoll gpt_primary   :interval "45s" "~/.config/eww/scripts/chatgpt-usage-info primary")
(defpoll gpt_secondary :interval "45s" "~/.config/eww/scripts/chatgpt-usage-info secondary")
(defpoll gpt_extra     :interval "45s" "~/.config/eww/scripts/chatgpt-usage-info extra")
(defpoll gpt_credits   :interval "45s" "~/.config/eww/scripts/chatgpt-usage-info credits")
(defpoll agy_gemini_5h     :interval "20s" "~/.config/eww/scripts/agy-usage-info gemini_5h")
(defpoll agy_gemini_weekly :interval "20s" "~/.config/eww/scripts/agy-usage-info gemini_weekly")
(defpoll agy_3p_5h         :interval "20s" "~/.config/eww/scripts/agy-usage-info third_party_5h")
(defpoll agy_3p_weekly     :interval "20s" "~/.config/eww/scripts/agy-usage-info third_party_weekly")
(defpoll keybinds_text :interval "2s" "~/.config/eww/scripts/hypr-keybinds-cheatsheet")
(defpoll notes_preview_text :interval "2s" "~/.config/eww/scripts/notes-preview")


(defwidget sys-chip [icon label value accent]
  (box :class "sys-chip ${accent}"
       :orientation "h"
       :space-evenly false
    (label :class "sys-icon" :text icon)
    (label :class "sys-label" :text label)
    (label :class "sys-value" :halign "center" :text value)))

(defwidget system-widget []
  (box :class "system-widget"
       :orientation "h"
       :space-evenly false
    (box :class "brand-chip" :orientation "h" :space-evenly false
      (label :class "brand-icon" :text "")
      (label :class "brand-title" :text "ARCH")
      (label :class "brand-subtitle" :halign "start" :text sys_time))
    (sys-chip :icon "󰻠" :label "CPU" :value sys_cpu :accent "cyan")
    (sys-chip :icon "󰘚" :label "RAM" :value sys_ram :accent "green")
    (sys-chip :icon "󰋊" :label "DISK" :value sys_disk :accent "mauve")
    (sys-chip :icon "󰈀" :label "I/O" :value sys_net :accent "blue")))

(defwindow system-widget
  :monitor 0
  :geometry (geometry :x "0px"
                      :y "3px"
                      :width "790px"
                      :height "38px"
                      :anchor "top center")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (system-widget))

(defwidget gpt-row [icon label value accent]
  (box :class "gpt-row ${accent}"
       :orientation "h"
       :space-evenly false
    (label :class "gpt-row-icon" :text icon)
    (label :class "gpt-row-label" :text label)
    (label :class "gpt-row-value" :halign "end" :text value)))

(defwidget chatgpt-usage []
  (box :class "chatgpt-usage"
       :orientation "v"
       :space-evenly false
    (box :class "gpt-header" :orientation "h" :halign "center" :space-evenly false
      (label :class "gpt-brand-icon" :text "󰚩")
      (label :class "gpt-title" :text "CHATGPT QUOTA")
      (label :class "gpt-title-muted" :text "(LEFT)"))
    (box :class "gpt-grid" :orientation "h" :space-evenly false
      (box :class "gpt-column quota" :orientation "v" :space-evenly false
        (gpt-row :icon "󰔟" :label "5 HOURS" :value gpt_primary :accent "cyan")
        (gpt-row :icon "󰸗" :label "WEEKLY" :value gpt_secondary :accent "mauve"))
      (box :class "gpt-column meta" :orientation "v" :space-evenly false
        (gpt-row :icon "󱎫" :label "FEATURE" :value gpt_extra :accent "blue")
        (gpt-row :icon "󰁹" :label "CREDITS" :value gpt_credits :accent "green")))))

(defwindow chatgpt-usage
  :monitor 0
  :geometry (geometry :x "4px"
                      :y "4px"
                      :width "382px"
                      :height "104px"
                      :anchor "top right")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (chatgpt-usage))

(defwidget gemini-usage []
  (box :class "gemini-usage"
       :orientation "v"
       :space-evenly false
    (box :class "gpt-header" :orientation "h" :halign "center" :space-evenly false
      (label :class "gpt-brand-icon" :text "󰚩")
      (label :class "gpt-title" :text "GEMINI QUOTA")
      (label :class "gpt-title-muted" :text "(LEFT)"))
    (box :class "gpt-grid" :orientation "h" :space-evenly false
      (box :class "gpt-column quota" :orientation "v" :space-evenly false
        (gpt-row :icon "󰔟" :label "GEM 5H" :value agy_gemini_5h :accent "cyan")
        (gpt-row :icon "󰸗" :label "GEM W" :value agy_gemini_weekly :accent "mauve"))
      (box :class "gpt-column meta" :orientation "v" :space-evenly false
        (gpt-row :icon "󱎫" :label "3P 5H" :value agy_3p_5h :accent "blue")
        (gpt-row :icon "󰁹" :label "3P W" :value agy_3p_weekly :accent "green")))))

(defwindow gemini-usage
  :monitor 0
  :geometry (geometry :x "4px"
                      :y "4px"
                      :width "382px"
                      :height "104px"
                      :anchor "top right")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (gemini-usage))

(defwidget keybinds-cheatsheet []
  (box :class "keybinds-panel"
       :orientation "v"
       :space-evenly false
    (scroll :class "keybinds-scroll"
            :hscroll false
            :vscroll true
      (label :class "keybinds-label"
             :halign "start"
             :valign "start"
             :wrap false
             :markup keybinds_text))))

(defwindow keybinds-cheatsheet
  :monitor 0
  :geometry (geometry :x "14px"
                      :y "0px"
                      :width "400px"
                      :height "74%"
                      :anchor "right center")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (keybinds-cheatsheet))

(defwidget notes-preview []
  (box :class "notes-panel"
       :orientation "v"
       :space-evenly false
    (scroll :class "notes-scroll"
            :hscroll false
            :vscroll true
      (label :class "notes-label"
             :halign "start"
             :valign "start"
             :wrap true
             :markup notes_preview_text))))

(defwindow notes-preview
  :monitor 0
  :geometry (geometry :x "14px"
                      :y "0px"
                      :width "360px"
                      :height "68%"
                      :anchor "left center")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (notes-preview))

