def split_hypr_args(raw: str) -> list[str]:
    parts = []
    current = []
    in_single = False
    in_double = False
    escape = False

    for ch in raw:
        if escape:
            current.append(ch)
            escape = False
            continue
        if ch == "\\":
            current.append(ch)
            escape = True
            continue
        if ch == "'" and not in_double:
            in_single = not in_single
            current.append(ch)
            continue
        if ch == '"' and not in_single:
            in_double = not in_double
            current.append(ch)
            continue
        if ch == "," and not in_single and not in_double:
            parts.append("".join(current).strip())
            current = []
        else:
            current.append(ch)
    parts.append("".join(current).strip())
    return parts


def strip_inline_comment(line: str) -> tuple[str, str]:
    try:
        tokens = shlex.split(line, comments=True, posix=True)
    except ValueError:
        tokens = []

    if "#" not in line:
        return line.rstrip(), ""

    in_single = in_double = False
    for i, ch in enumerate(line):
        if ch == "'" and not in_double:
            in_single = not in_single
        elif ch == '"' and not in_single:
            in_double = not in_double
        elif ch == "#" and not in_single and not in_double:
            return line[:i].rstrip(), line[i + 1 :].strip()
    return line.rstrip(), ""


def readable_mods(mods: str, variables: dict[str, str]) -> str:
    mods = mods.strip()
    if not mods:
        return ""
    for name, value in variables.items():
        mods = mods.replace(name, value)
    mods = re.sub(r"\s+", " + ", mods.strip())
    return mods


def readable_key(key: str) -> str:
    key = key.strip()
    return KEY_NAMES.get(key, key)


def describe(dispatcher: str, params: str, comment: str) -> str:
    if comment and comment.lower() not in {"dwindle"}:
        return COMMENT_TRANSLATIONS.get(comment, comment)

    if dispatcher == "movefocus":
        return {
            "l": "Focus left",
            "r": "Focus right",
            "u": "Focus up",
            "d": "Focus down",
        }.get(params.strip(), "Move focus")

    if dispatcher == "resizeactive":
        values = params.replace(",", " ").split()
        if len(values) >= 2:
            x, y = values[0], values[1]
            if y.startswith("-"):
                return "Decrease height"
            if y != "0":
                return "Increase height"
            if x.startswith("-"):
                return "Decrease width"
            if x != "0":
                return "Increase width"
        return "Resize window"

    if dispatcher == "workspace":
        clean = params.strip()
        if clean.startswith("special:"):
            return "Show/hide scratchpad"
        if clean.startswith("e+"):
            return "Next workspace"
        if clean.startswith("e-"):
            return "Previous workspace"
        return f"Go to workspace {clean}"

    if dispatcher == "movetoworkspace":
        clean = params.strip()
        if clean.startswith("special:"):
            return "Send to scratchpad"
        return f"Move to workspace {clean}"

    haystack = f"{dispatcher} {params}"
    for needle, text in COMMAND_DESCRIPTIONS:
        if needle in haystack:
            return text
    if dispatcher == "exec":
        return params.replace("$HOME", "~")
    return f"{dispatcher} {params}".strip()


def section_name(comment: str) -> str | None:
    clean = comment.strip("# ").strip()
    if not clean or clean in SECTION_IGNORE:
        return None
    return SECTION_RENAMES.get(clean, clean)


def parse() -> list[tuple[str, list[tuple[str, str]]]]:
    if not CONFIG.exists():
        return [("Error", [("Sin archivo", f"No existe {CONFIG}")])]

    variables: dict[str, str] = {}
    current = "General"
    sections: list[tuple[str, list[tuple[str, str]]]] = []
    rows: list[tuple[str, str]] = []

    def flush() -> None:
        nonlocal rows
        if rows:
            sections.append((current, rows))
            rows = []

    for raw_line in CONFIG.read_text(encoding="utf-8").splitlines():
        stripped = raw_line.strip()
        if not stripped:
            continue

        if stripped.startswith("#"):
            maybe = section_name(stripped)
            if maybe:
                flush()
                current = maybe
            continue

        if stripped.startswith("$") and "=" in stripped:
            name, value = stripped.split("=", 1)
            variables[name.strip()] = value.strip().split("#", 1)[0].strip()
            continue

        line, comment = strip_inline_comment(raw_line)
        if "=" not in line:
            continue
        kind, rest = line.split("=", 1)
        kind = kind.strip()
        if not kind.startswith("bind"):
            continue

        parts = split_hypr_args(rest)
        if len(parts) < 3:
            continue
        mods, key, dispatcher = parts[0], parts[1], parts[2]
        params = ", ".join(parts[3:]) if len(parts) > 3 else ""

        combo_parts = [readable_mods(mods, variables), readable_key(key)]
        combo = " + ".join(part for part in combo_parts if part)
        rows.append((combo, describe(dispatcher, params, comment)))

    flush()
    return sections


def render() -> str:
    sections = parse()
    out: list[str] = []
    out.append('<span foreground="#dff7ff" size="large" weight="900">󰌌  KEYBINDS</span>')
    out.append('<span foreground="#78c7e8" size="small">SUPER + K to hide · source: keybinds.conf</span>')
    out.append("")

    for title, rows in sections:
        if title == "Switch workspace":
            rows = [("SUPER + #", "Go to workspace")]
        elif title == "Move window to workspace":
            rows = [("ALT + #", "Move window")]


        out.append(f'<span foreground="#00e5ff" weight="900">▸ {html.escape(title.upper())}</span>')
        out.append('<span foreground="#4f8099">────────────────────────────────────</span>')
        for combo, desc in rows:
            combo_text = html.escape(combo.ljust(18))
            desc_text = html.escape(desc)
            out.append(
                f'<span foreground="#bff7ff" background="#073149" weight="900"> {combo_text} </span>'
                f' <span foreground="#4f8099">│</span> '
                f'<span foreground="#c8efff">{desc_text}</span>'
            )
        out.append("")

    return "\n".join(out).rstrip()


if __name__ == "__main__":
    print(render())
